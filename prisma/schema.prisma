generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  image     String?  // base64 data URL ou URL externa
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id           String       @id @default(cuid())
  name         String
  planName     String?
  description  String?
  url          String?
  loginUser    String?
  loginPass    String?
  loginType    LoginType    @default(PASSWORD)
  cost         Float?
  currency     String       @default("BRL")
  billingCycle BillingCycle @default(MONTHLY)
  costCenter   String?
  team         String?
  responsible  String?
  isActive     Boolean      @default(true)
  renewalDate  DateTime?
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum Role {
  ADMIN
  USER
}

enum BillingCycle {
  MONTHLY
  ANNUALLY
  ONE_TIME
  USAGE
}

enum LoginType {
  PASSWORD
  CODE
}

model Automation {
  id                String           @id @default(cuid())
  name              String
  type              AutomationType   @default(AUTOMATION)
  shortDesc         String?
  fullDesc          String?
  thumbnailUrl      String?
  link              String?
  status            AutomationStatus @default(ACTIVE)
  creator           String?
  tools             String[]
  roiHoursSaved     Float?
  roiMonthlySavings Float?
  roiDescription    String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

enum AutomationType {
  AUTOMATION
  AGENT
}

enum AutomationStatus {
  ACTIVE
  INACTIVE
  TESTING
}

model Expense {
  id          String          @id @default(cuid())
  month       String          // formato "2026-02"
  date        String?         // formato "2026-02-14" (opcional, quando há data exata)
  value       Float           // em BRL
  category    ExpenseCategory
  description String?         // nome do instrutor/prestador
  source      ExpenseSource   @default(MANUAL)
  externalId  String?         @unique // task ID do ClickUp (deduplicação)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum ExpenseCategory {
  INSTRUTOR
  EDITOR_FREELANCER
  EDITOR_EXTERNO
  SUPORTE_EDUCACIONAL
}

enum ExpenseSource {
  CLICKUP
  UPLOAD
  MANUAL
}

model Process {
  id          String        @id @default(cuid())
  title       String
  description String?
  tags        String[]
  status      ProcessStatus @default(DRAFT)
  creatorId   String
  creatorName String
  flowData    String?       // JSON.stringify({ nodes, edges })
  richText    String?       // JSON.stringify(TipTap document)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum ProcessStatus {
  DRAFT
  PUBLISHED
}
